generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id                  Int           @id @default(autoincrement())
  email               String        @unique
  password_hash       String
  intentos_fallidos   Int           @default(0)
  bloqueado_hasta     DateTime?
  fecha_creacion      DateTime      @default(now())
  fecha_actualizacion DateTime      @updatedAt
  rol                 RolUsuario
  estado              EstadoUsuario @default(ACTIVO)
  auditorias          Auditoria[]
  reservas            Reserva[]
  socio               Socio?
  ventas              Venta[]
}

model Socio {
  id                      Int            @id @default(autoincrement())
  usuario_id              Int            @unique
  documento               String         @unique
  nombre                  String
  apellido                String
  telefono                String
  fecha_alta              DateTime       @default(now())
  consentimiento_aceptado Boolean        @default(false)
  fecha_consentimiento    DateTime?
  fecha_creacion          DateTime       @default(now())
  fecha_actualizacion     DateTime       @updatedAt
  estado                  EstadoSocio    @default(ACTIVO)
  notificaciones          Notificacion[]
  reservas                Reserva[]
  usuario                 Usuario        @relation(fields: [usuario_id], references: [id])
  ventas                  Venta[]
}

model Producto {
  id                  Int               @id @default(autoincrement())
  nombre              String            @unique
  descripcion         String?
  precio_venta_actual Float
  estado              EstadoProducto    @default(ACTIVO)
  fecha_creacion      DateTime          @default(now())
  fecha_actualizacion DateTime          @updatedAt
  genetica            GeneticaProducto?
  porcentaje_thc      Float?
  tipo                TipoProducto
  unidad_medida       UnidadMedida
  imagen_url          String?
  compras_detalle     CompraDetalle[]
  movimientos_stock   MovimientoStock[]
  reservas_detalle    ReservaDetalle[]
  stock               Stock?
  ventas_detalle      VentaDetalle[]
}

model Stock {
  id                  Int      @id @default(autoincrement())
  producto_id         Int      @unique
  cantidad_total      Float    @default(0)
  cantidad_reservada  Float    @default(0)
  cantidad_disponible Float    @default(0)
  fecha_actualizacion DateTime @updatedAt
  producto            Producto @relation(fields: [producto_id], references: [id])
}

model MovimientoStock {
  id              Int                 @id @default(autoincrement())
  producto_id     Int
  tipo            TipoMovimientoStock
  cantidad        Float
  referencia_id   Int?
  fecha_creacion  DateTime            @default(now())
  referencia_tipo String?
  producto        Producto            @relation(fields: [producto_id], references: [id])
}

model Proveedor {
  id                  Int             @id @default(autoincrement())
  nombre              String
  contacto            String?
  telefono            String?
  email               String?
  estado              EstadoProveedor @default(ACTIVO)
  fecha_creacion      DateTime        @default(now())
  fecha_actualizacion DateTime        @updatedAt
  compras             Compra[]
}

model Compra {
  id                  Int             @id @default(autoincrement())
  proveedor_id        Int
  fecha               DateTime        @default(now())
  estado              EstadoCompra    @default(REGISTRADA)
  observaciones       String?
  fecha_creacion      DateTime        @default(now())
  fecha_actualizacion DateTime        @updatedAt
  proveedor           Proveedor       @relation(fields: [proveedor_id], references: [id])
  detalles            CompraDetalle[]
}

model CompraDetalle {
  id              Int      @id @default(autoincrement())
  compra_id       Int
  producto_id     Int
  cantidad        Float
  precio_unitario Float
  subtotal        Float
  compra          Compra   @relation(fields: [compra_id], references: [id])
  producto        Producto @relation(fields: [producto_id], references: [id])
}

model Venta {
  id                  Int            @id @default(autoincrement())
  socio_id            Int
  usuario_id          Int
  fecha               DateTime       @default(now())
  estado              EstadoVenta    @default(REGISTRADA)
  observaciones       String?
  fecha_creacion      DateTime       @default(now())
  fecha_actualizacion DateTime       @updatedAt
  socio               Socio          @relation(fields: [socio_id], references: [id])
  usuario             Usuario        @relation(fields: [usuario_id], references: [id])
  detalles            VentaDetalle[]
}

model VentaDetalle {
  id              Int      @id @default(autoincrement())
  venta_id        Int
  producto_id     Int
  cantidad        Float
  precio_unitario Float
  producto        Producto @relation(fields: [producto_id], references: [id])
  venta           Venta    @relation(fields: [venta_id], references: [id])
}

model Reserva {
  id                  Int                @id @default(autoincrement())
  socio_id            Int
  usuario_id          Int
  fecha_solicitud     DateTime           @default(now())
  fecha_limite_retiro DateTime
  estado              EstadoReserva      @default(PENDIENTE)
  observaciones       String?
  fecha_actualizacion DateTime           @updatedAt
  historial           HistorialReserva[]
  socio               Socio              @relation(fields: [socio_id], references: [id])
  usuario             Usuario            @relation(fields: [usuario_id], references: [id])
  detalles            ReservaDetalle[]
}

model ReservaDetalle {
  id          Int      @id @default(autoincrement())
  reserva_id  Int
  producto_id Int
  cantidad    Float
  producto    Producto @relation(fields: [producto_id], references: [id])
  reserva     Reserva  @relation(fields: [reserva_id], references: [id])
}

model HistorialReserva {
  id            Int           @id @default(autoincrement())
  reserva_id    Int
  estado        EstadoReserva
  fecha         DateTime      @default(now())
  observaciones String?
  reserva       Reserva       @relation(fields: [reserva_id], references: [id])
}

model Auditoria {
  id             Int      @id @default(autoincrement())
  usuario_id     Int
  accion         String
  entidad        String
  entidad_id     Int?
  detalle        String?
  fecha_creacion DateTime @default(now())
  usuario        Usuario  @relation(fields: [usuario_id], references: [id])
}

model Notificacion {
  id             Int                @id @default(autoincrement())
  socio_id       Int?
  tipo           String
  mensaje        String
  canal          String
  estado         EstadoNotificacion @default(PENDIENTE)
  origen_id      Int?
  fecha_envio    DateTime?
  fecha_creacion DateTime           @default(now())
  origen_tipo    String?
  socio          Socio?             @relation(fields: [socio_id], references: [id])
}

enum RolUsuario {
  ADMIN
  SOCIO
}

enum EstadoUsuario {
  ACTIVO
  INACTIVO
  BLOQUEADO
}

enum EstadoSocio {
  ACTIVO
  INACTIVO
  SUSPENDIDO
}

enum EstadoProducto {
  ACTIVO
  INACTIVO
}

enum TipoProducto {
  FLOR
  SEMILLA
}

enum UnidadMedida {
  GRAMOS
  UNIDADES
}

enum GeneticaProducto {
  INDICA
  SATIVA
  HIBRIDA
}

enum EstadoProveedor {
  ACTIVO
  INACTIVO
}

enum EstadoReserva {
  PENDIENTE
  CONFIRMADA
  RECHAZADA
  CANCELADA
  VENCIDA
  FINALIZADA
}

enum EstadoVenta {
  REGISTRADA
  ANULADA
}

enum EstadoCompra {
  REGISTRADA
  ANULADA
}

enum EstadoNotificacion {
  PENDIENTE
  ENVIADA
  ERROR
}

enum TipoMovimientoStock {
  INGRESO
  EGRESO
  RESERVA
  LIBERACION_RESERVA
  AJUSTE
}
